# ── Bridge configuration (Railway) ──────────────────────────────────────────
# Copy to .env for local runs. On Railway, set these as service variables.

# REQUIRED. Where the eve agent is deployed (Vercel). The bridge POSTs messages
# to <EVE_URL>/eve/v1/whatsapp/message.
EVE_URL=https://your-agent.vercel.app

# REQUIRED. Shared secret — must match WHATSAPP_BRIDGE_SECRET on the eve/Vercel
# side. Guards both message forwarding and the bridge's HTTP API. Any long
# random string.
WHATSAPP_BRIDGE_SECRET=change-me-to-a-long-random-string

# Where Baileys persists its login. On Railway, mount a volume and point this at
# it (e.g. /data/auth) so the login survives restarts (no re-scanning the QR).
AUTH_DIR=./auth

# Name attributed to the bot's own messages. Match the persona name in
# agent/lib/base-instructions.ts.
BOT_NAME=Robin

# Trigger: mention (default; reply only when @-mentioned or quote-replied) |
# prefix (reply to messages starting with TRIGGER_PREFIX) | all (reply to every
# group message — test groups only).
TRIGGER_MODE=mention
TRIGGER_PREFIX=!bot

# Optional: comma-separated group JIDs to limit the bot to. Empty = all groups.
ALLOWED_GROUPS=

# Optional: pair via 8-digit code instead of QR. International format, no "+".
PAIRING_NUMBER=

# Optional: JID the maintainer is DMed at when a member files a feature request
# or bug report via the agent (e.g. 15551234567@s.whatsapp.net). Empty = reports
# are accepted but not delivered.
MAINTAINER_JID=

# ── Media (all on by default; set to "false" to disable) ─────────────────────
VISION_ENABLED=true        # forward shared images so the agent can see them
DOCS_ENABLED=true          # forward PDFs/office/text files so the agent can read them
AUDIO_ENABLED=true         # transcribe voice notes (also needs OPENAI_API_KEY)
# OPENAI_API_KEY=          # required for AUDIO_ENABLED (voice-note transcription)

LOG_LEVEL=info

# ── Agent side (set these on Vercel, NOT in this file) ───────────────────────
# WHATSAPP_BRIDGE_SECRET  — the same value as above.
# BRIDGE_URL              — the bridge's public URL, so the agent's tools can read
#                           the live buffer/memory back (e.g.
#                           https://your-bridge.up.railway.app).
# MEMORY_ADMIN_JIDS       — comma-separated admin JIDs allowed to save memory.
# FIRECRAWL_API_KEY       — optional; enables the read-url tool for JS pages/PDFs.
