{
  "name": "eve-whatsapp-group-agent",
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#data/*": "./agent/lib/data/*",
    "#*": "./agent/*",
    "#evals/*": "./evals/*"
  },
  "scripts": {
    "build": "eve build",
    "dev": "eve dev",
    "start": "eve start",
    "test": "vitest run",
    "test:evals": "EVE_DOCKER_PATH=/usr/bin/false eve eval --strict",
    "smoke": "node scripts/smoke.ts",
    "typecheck": "tsc --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "@vercel/connect": "^0.4.2",
    "ai": "7.0.32",
    "eve": "^0.26.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.x",
    "lefthook": "^2.1.10",
    "microsandbox": "^0.5.10",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "7.0.2",
    "ultracite": "7.9.4",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "ai": "7.0.32"
  },
  "engines": {
    "node": "24.x"
  }
}
