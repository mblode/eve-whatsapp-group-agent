{
  "name": "eve-whatsapp-group-agent",
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#data/*": "./agent/lib/data/*",
    "#*": "./agent/*",
    "#evals/*": "./evals/*"
  },
  "scripts": {
    "build": "eve build",
    "dev": "eve dev",
    "start": "eve start",
    "test": "vitest run",
    "test:evals": "eve eval --strict",
    "smoke": "node scripts/smoke.ts",
    "typecheck": "tsgo",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "@vercel/connect": "^0.3.2",
    "ai": "7.0.19",
    "eve": "^0.22.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@typescript/native-preview": "^7.0.0-dev.20260707.2",
    "lefthook": "^2.1.10",
    "microsandbox": "^0.6.6",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "ultracite": "^7.9.3",
    "vitest": "^4.1.10"
  },
  "resolutions": {
    "ai": "7.0.19"
  },
  "overrides": {
    "ai": "7.0.19",
    "eve": {
      "microsandbox": "$microsandbox"
    }
  },
  "engines": {
    "node": "24.x"
  }
}
