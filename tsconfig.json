{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": [
    "agent/**/*.ts",
    "tests/**/*.ts",
    "evals/**/*.ts",
    "scripts/**/*.ts",
    ".eve/**/*.d.ts"
  ]
}
